# ============================================================================
# API
# ============================================================================
# URL del servicio backend en Railway (se asigna al desplegar)
NEXT_PUBLIC_API_URL=https://TU-BACKEND.up.railway.app/v1

# ============================================================================
# CLERK AUTHENTICATION
# ============================================================================
# Obtén esta clave en: https://dashboard.clerk.com → API Keys
# IMPORTANTE: usar clave de PRODUCCIÓN (pk_live_), no test
# NOTA: CLERK_SECRET_KEY va SOLO en el backend, NO aquí
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_TU_PUBLISHABLE_KEY

# ============================================================================
# SEO / SITE
# ============================================================================
# URL pública del frontend en Railway
NEXT_PUBLIC_SITE_URL=https://TU-FRONTEND.up.railway.app

# ============================================================================
# NOTAS PARA RAILWAY
# ============================================================================
# NEXT_PUBLIC_* se inyectan en BUILD TIME — debes declararlas en
# Railway → Service → Variables ANTES de hacer el deploy.
# Si las añades después, es necesario forzar un redeploy.
