# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=production
PORT=3001
API_PREFIX=v1
FRONTEND_URL=https://TU-FRONTEND.up.railway.app
LOG_LEVEL=info

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Railway provisiona esto automáticamente — cópialo desde las Variables del plugin
DATABASE_URL=postgresql://user:pass@host:5432/railway
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=true

# ============================================================================
# REDIS (Cache & Queue)
# ============================================================================
# Railway provisiona esto automáticamente — cópialo desde las Variables del plugin
REDIS_URL=redis://user:pass@host:6379
REDIS_QUEUE_NAME=challenge-validation
REDIS_CACHE_TTL_MATCH=86400
REDIS_CACHE_TTL_MATCHLIST=90

# ============================================================================
# AUTHENTICATION (JWT & COOKIES)
# ============================================================================
# IMPORTANT: Generate strong secrets in production with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Development values shown below are placeholders only
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERA_CON_CRYPTO_RANDOMBYTES_32_HEX
JWT_EXPIRES_IN=15m
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  (valor DIFERENTE al JWT_SECRET)
REFRESH_TOKEN_SECRET=GENERA_CON_CRYPTO_RANDOMBYTES_32_HEX_DIFERENTE
REFRESH_TOKEN_EXPIRES_IN=7d
# Genera con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
COOKIE_SECRET=GENERA_CON_CRYPTO_RANDOMBYTES_16_HEX
BCRYPT_ROUNDS=12
CORS_ORIGIN=https://TU-FRONTEND.up.railway.app

# ============================================================================
# GOOGLE OAUTH
# ============================================================================
# Crea credenciales en: https://console.cloud.google.com
# Authorized redirect URI: https://TU-BACKEND.up.railway.app/v1/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://TU-BACKEND.up.railway.app/v1/auth/google/callback

# ============================================================================
# RIOT API (League of Legends)
# ============================================================================
# Development key: https://developer.riotgames.com
# - Development keys expire every 24h at midnight UTC
# - Production keys require application approval (~2-4 weeks)
# - If validation fails with 403 errors, regenerate your dev key
RIOT_API_KEY=RGAPI-xxxx
RIOT_API_BASE_URL=https://la1.api.riotgames.com
RIOT_API_REGIONAL_URL=https://americas.api.riotgames.com
RIOT_RATE_LIMIT_PER_SECOND=18
RIOT_RATE_LIMIT_PER_2MIN=90
RIOT_MAX_RETRIES=3
RIOT_RETRY_BASE_DELAY_MS=5000

# ============================================================================
# ECONOMY
# ============================================================================
SIGNUP_BONUS_COINS=10
CHALLENGE_CREATION_COST=1
VALIDATION_COOLDOWN_MINUTES=1

# ============================================================================
# CLERK AUTHENTICATION
# ============================================================================
# Get these from https://dashboard.clerk.com after claiming your Keyless app
# CLERK_SECRET_KEY is required for the backend /auth/clerk-sync endpoint
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# ============================================================================
# WORKER (BullMQ Job Processor)
# ============================================================================
WORKER_CONCURRENCY=2
JOB_MAX_RETRIES=3
JOB_BACKOFF_DELAY_MS=5000
JOB_RETENTION_COMPLETED=24
JOB_RETENTION_FAILED=168
